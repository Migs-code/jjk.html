<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Multi-Modal Site</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            background-color: #f4f4f4;
        }

        .nav-container {
            background-color: #000;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 50px;
            color: white;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            border: 2px solid white;
            padding: 5px 12px;
            border-radius: 50%;
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 40px;
        }

        .nav-links {
            display: flex;
            gap: 30px;
            list-style: none;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            font-size: 18px;
            transition: 0.3s;
        }

        .nav-links a:hover {
            color: #ff4757;
        }

        .cta-button {
            background-color: white;
            color: black;
            padding: 10px 20px;
            border-radius: 5px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
            cursor: pointer;
        }

        .cta-button:hover {
            background-color: #ff4757;
            color: white;
        }

        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .modal-overlay.show {
            opacity: 1;
            pointer-events: auto;
        }

        .modal {
            background: white;
            padding: 40px;
            width: 90%;
            max-width: 400px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            transform: scale(0.8);
            transition: transform 0.3s ease;
        }

        .modal-overlay.show .modal {
            transform: scale(1);
        }

        .modal h2 {
            font-size: 28px;
            margin-bottom: 20px;
            color: #333;
        }

        
        .form-group {
            text-align: left;
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-size: 14px;
            font-weight: bold;
            color: #555;
        }

        .form-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 16px;
        }

        .form-group input:focus {
            outline: none;
            border-color: #ff4757;
        }

        .forgot-pass {
            display: block;
            text-align: right;
            font-size: 13px;
            color: #ff4757;
            text-decoration: none;
            margin-bottom: 20px;
        }

        .login-submit {
            width: 100%;
            background: #000;
            color: white;
            border: none;
            padding: 14px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            transition: 0.3s;
        }

        .login-submit:hover {
            background: #ff4757;
        }

        .close-btn {
            background: none;
            border: none;
            color: #888;
            margin-top: 15px;
            cursor: pointer;
            font-size: 14px;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <nav class="nav-container">
        <div class="logo">MD</div>
        <div class="nav-right">
            <ul class="nav-links">
                <li><a  href="#">Home</a></li>
                <li><a id="open-about" href="#">About</a></li>
                <li><a href="#">Product</a></li>
                <li><a href="#">Service</a></li>
            </ul>
            <a id="open-login" class="cta-button">Get Started</a>
        </div>
    </nav>

    <div id="modal-about" class="modal-overlay">
        <div class="modal">
            <h2>About MD</h2>
            <p style="color: #555; line-height: 1.6; margin-bottom: 20px;">Welcome to MD. This platform is built with a focus on minimalist design and high-performance user experiences.</p>
            <button class="login-submit close-trigger">Close</button>
        </div>
    </div>

    <div id="modal-login" class="modal-overlay">
        <div class="modal">
            <h2>Welcome Back</h2>
            <form id="loginForm">
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" placeholder="email@example.com" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" placeholder="••••••••" required>
                </div>
                <a href="#" class="forgot-pass">Forgot password?</a>
                <button type="submit" class="login-submit">Login</button>
            </form>
            <button class="close-btn close-trigger">Cancel</button>
        </div>
    </div>

    <script>
        const aboutBtn = document.getElementById('open-about');
        const loginBtn = document.getElementById('open-login');
        
        const aboutModal = document.getElementById('modal-about');
        const loginModal = document.getElementById('modal-login');
        
        const closeTriggers = document.querySelectorAll('.close-trigger');

       
        aboutBtn.addEventListener('click', (e) => {
            e.preventDefault();
            aboutModal.classList.add('show');
        });

        loginBtn.addEventListener('click', (e) => {
            e.preventDefault();
            loginModal.classList.add('show');
        });

     
        closeTriggers.forEach(trigger => {
            trigger.addEventListener('click', () => {
                aboutModal.classList.remove('show');
                loginModal.classList.remove('show');
            });
        });

       
        window.addEventListener('click', (e) => {
            if (e.target.classList.contains('modal-overlay')) {
                e.target.classList.remove('show');
            }
        });

        document.getElementById('loginForm').addEventListener('submit', (e) => {
            e.preventDefault();
            alert('Login successful! (This is a demo)');
            loginModal.classList.remove('show');
        });
    </script>
</body>
</html>